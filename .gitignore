# Ignore DS_Store
._.DS_Store
.DS_Store
.DS_Store?

# Ignore DS_Store on subfolders
**/.DS_Store
**/._.DS_Store

# Ignore .env
.env
**/.env

# Ignore IDE
**/.vscode/
**/.idea

# Ignore secrets except examples
**/secrets/*
!/secrets/db_password.txt.example

# Ignore local application properties (development without docker)
**/application-local.properties

# Ignore nginx certification (make will create it for you)
nginx/certs/**

# Ignore build artifacts
**/.gradle/
**/bin/
**/build/

# Ignore AI tools
.claude/
**/.claude/
